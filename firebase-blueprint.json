{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "currentMonthId": {
          "type": "string",
          "description": "The ID of the currently selected month in the dashboard"
        }
      }
    },
    "MonthlyData": {
      "title": "MonthlyData",
      "description": "Sales and goal data for a specific month",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "month": {
          "type": "string"
        },
        "vitralabSales": {
          "type": "number"
        },
        "onixlabSales": {
          "type": "number"
        },
        "nativalabSales": {
          "type": "number"
        },
        "goal": {
          "type": "number"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["id", "month", "vitralabSales", "onixlabSales", "nativalabSales", "goal", "notes"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile document"
    },
    "users/{userId}/monthlyData/{monthId}": {
      "schema": {
        "$ref": "#/entities/MonthlyData"
      },
      "description": "Monthly sales data for the user"
    }
  }
}
